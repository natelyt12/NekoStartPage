{
    "manifest_version": 3,
    "name": "Neko Startpage",
    "version": "1",
    "description": "A highly customizable new tab page with useful widgets, dynamic animations, and stunning wallpapers.",
    "author": "Natelyt",
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "host_permissions": ["https://*.wallhaven.cc/*"],
    "permissions": ["storage", "unlimitedStorage"],
    "icons": {
        "16": "assets/icons/icon-16.png",
        "48": "assets/icons/icon-48.png",
        "128": "assets/icons/icon-128.png"
    }
}
